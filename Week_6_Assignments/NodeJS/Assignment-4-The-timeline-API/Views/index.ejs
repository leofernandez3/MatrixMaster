<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>The Timeline</title>
</head>
<body>
<div class="container mt-5">
  <h1 class="mb-4">The Timeline</h1>

  <form action="/add-post" method="POST" class="mb-4">
    <textarea name="post" class="form-control mb-2" placeholder="Write your post here (min 25 chars)" required></textarea>
    <button type="submit" class="btn btn-primary">Add Post</button>
  </form>


  <% posts.forEach(post => { %>
    <div class="card mb-3">
      <div class="card-body">
        <p class="card-text"><%= post.body %></p>
        <p class="text-muted small">Created At: <%= post.createdAt.toLocaleString() %></p>

        <form action="/delete-post/<%= post._id %>" method="POST" class="d-inline">
          <button class="btn btn-danger btn-sm">Delete</button>
        </form>
        <form action="/update-post/<%= post._id %>" method="POST" class="d-inline ms-2">
          <input type="text" name="post" placeholder="Update post" class="form-control d-inline w-auto" required>
          <button class="btn btn-warning btn-sm">Update</button>
        </form>
        <hr>
        <h6>Comments:</h6>
        <% if(!post.comments || post.comments.length === 0) { %>
          <p class="text-muted small">No comments yet.</p>
        <% } else { %>
          <% post.comments.forEach(comment => { %>
            <div class="card mb-2">
              <div class="card-body">
                <p><%= comment.body %></p>
                <p class="text-muted small">Created at: <%= comment.createdAt.toLocaleString() %></p>
                <form action="/delete-comment/<%= comment._id %>" method="POST" class="d-inline">
                  <button class="btn btn-danger btn-sm">Delete Comment</button>
                </form>
              </div>
            </div>
          <% }) %>
        <% } %>

        <form action="/add-comment/<%= post._id %>" method="POST" class="mt-2">
          <textarea name="comment" class="form-control mb-1" placeholder="Write your comment (min 25 chars)" required></textarea>
          <button class="btn btn-success btn-sm">Add Comment</button>
        </form>
      </div>
    </div>
  <% }); %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>