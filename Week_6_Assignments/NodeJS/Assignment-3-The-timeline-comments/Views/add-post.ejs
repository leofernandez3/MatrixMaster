<!DOCTYPE html>
<html>
<head>
  <title>Add/Edit Post</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container py-5">
    <h1 class="mb-4 text-center"><%= post ? "Edit Post" : "Add New Post" %></h1>
    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <form method="POST" action="<%= post ? '/update-post/' + post._id : '/add-post' %>">
      <div class="mb-3">
        <textarea name="post" class="form-control" rows="5" placeholder="Write your post here..."><%= post ? post.post : "" %></textarea>
      </div>
      <button type="submit" class="btn btn-success"><%= post ? "Update Post" : "Add Post" %></button>
      <a href="/" class="btn btn-secondary">Cancel</a>
    </form>
  </div>
</body>
</html>