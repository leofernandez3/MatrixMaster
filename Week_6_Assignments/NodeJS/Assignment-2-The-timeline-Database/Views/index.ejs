<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>The Timeline</title>
</head>
<body>
<div class="container mt-5">
  <h1 class="mb-4">The Timeline</h1>

  <% if(error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <form action="/add-post" method="POST" class="mb-4">
    <textarea name="post" class="form-control mb-2" placeholder="Write your post here (min 25 chars)" required></textarea>
    <button type="submit" class="btn btn-primary">Add Post</button>
  </form>

  <% posts.forEach(post => { %>
    <div class="card mb-3">
      <div class="card-body">
        <p class="card-text"><%= post.post %></p>
        <p class="text-muted small">Created At: <%= post.createdAt.toLocaleString() %></p>

        <form action="/delete-post/<%= post._id %>" method="POST" class="d-inline">
          <button class="btn btn-danger btn-sm">Delete</button>
        </form>

        <form action="/update-post/<%= post._id %>" method="POST" class="d-inline ms-2">
          <input type="text" name="post" placeholder="Update post" class="form-control d-inline w-auto" required>
          <button class="btn btn-warning btn-sm">Update</button>
        </form>
      </div>
    </div>
  <% }); %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>