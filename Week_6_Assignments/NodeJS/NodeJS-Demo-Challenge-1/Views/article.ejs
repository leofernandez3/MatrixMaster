<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Article</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5">
        <a href="/">Back</a>
        <h2 class="mt-3"> <%= article.title %> </h2>
        <p class="mt-4"> <%= article.article %> </p>
        <hr>
        <a href="/edit/article/<%= article._id %>"> Edit article </a> | <a href="/delete/article/<%= article._id %>"> Delete article </a>
    </div>
</body>
</html>